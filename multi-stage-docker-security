# Stage 1: Build the Vite Application
FROM node:18-slim AS builder

WORKDIR /app
# Copy package.json and package-lock.json first
COPY package*.json ./

# Install all dependencies, including devDependencies (needed for build)
RUN npm install --no-fund --no-audit

# Copy the rest of the application
COPY . .

# Build the Vite app
RUN npm run build

# Stage 2: Run with a Minimal Secure Base Image
FROM node:18-slim AS runner
WORKDIR /app

# Add a non-root user for security
RUN useradd --no-create-home --shell /bin/bash appuser

# Copy built application from builder
COPY --from=builder /app/dist ./dist

# Copy node_modules and package.json (ensure Vite is included)
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./package.json

# Set permissions for security
RUN chown -R appuser:appuser /app

# Switch to the non-root user
USER appuser

# Expose the port
EXPOSE 3000

# Start the Vite preview server securely
CMD ["npx", "vite", "preview", "--port", "3000", "--host", "0.0.0.0"]
